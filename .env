# ═══════════════════════════════════════════════════════
# Supply Chain AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════

# ── PostgreSQL / pgAdmin Credentials ──────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supply_chain
DB_USER=postgres
DB_PASSWORD=admin
DB_SCHEMA=public
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# pgAdmin Web UI
PGADMIN_DEFAULT_EMAIL=admin@supplychain.ai
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# ── Flask App ──────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=supply-chain-ai-dev-secret-change-in-prod
PORT=5000
HOST=0.0.0.0

# ── Live Stream Settings ───────────────────────────────
# How many records to stream per batch
STREAM_BATCH_SIZE=5
# Interval in seconds between each batch
STREAM_INTERVAL_SECONDS=10
# Table to stream from (shipments_master or route_events)
STREAM_TABLE=route_events
# ORDER BY column for consistent streaming
STREAM_ORDER_COL=event_timestamp

# ── File Upload ────────────────────────────────────────
UPLOAD_FOLDER=./data/uploads
MAX_UPLOAD_MB=100

# ── ETL Settings ──────────────────────────────────────
ETL_CHUNK_SIZE=10000
ETL_LOG_LEVEL=INFO
