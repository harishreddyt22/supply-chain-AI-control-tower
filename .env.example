# ═══════════════════════════════════════════════════════
# Supply Chain AI — Example Environment Variables
# Copy to .env and fill in your actual values
# ═══════════════════════════════════════════════════════

DB_HOST=localhost
DB_PORT=5432
DB_NAME=supply_chain_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_SCHEMA=public
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

PGADMIN_DEFAULT_EMAIL=admin@supplychain.ai
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING
PORT=5000
HOST=0.0.0.0

STREAM_BATCH_SIZE=5
STREAM_INTERVAL_SECONDS=10
STREAM_TABLE=route_events
STREAM_ORDER_COL=event_timestamp

UPLOAD_FOLDER=./data/uploads
MAX_UPLOAD_MB=100

ETL_CHUNK_SIZE=10000
ETL_LOG_LEVEL=INFO
